# Supabase (server-side only — never expose SERVICE_ROLE_KEY to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n recommendation engine webhook (production URL, not the -test URL)
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/your-path
